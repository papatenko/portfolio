---
import { site } from '../data/site';
import SocialLinks from './SocialLinks.astro';
---

<section class="hero container" aria-label="Introduction">
  <div class="hero-text">
    <p class="mono kicker" data-enter style="--enter-i: 0">
      <span class="prompt">~$</span> whoami
    </p>
    <h1 data-enter style="--enter-i: 1">Hi, I'm <span class="grad">{site.firstName}</span>.</h1>
    <p class="roles mono" aria-live="polite" data-enter style="--enter-i: 2">
      <span id="typed">{site.roles[0]}</span><span class="caret">&nbsp;</span>
    </p>
    <p class="intro" data-enter style="--enter-i: 3">{site.intro}</p>
    <div class="cta" data-enter style="--enter-i: 4">
      <a href="/#projects" class="btn btn-primary">View Projects</a>
      <a href={site.resumePath} class="btn btn-ghost" download>Download Resume</a>
    </div>
    <div data-enter style="--enter-i: 5">
      <SocialLinks class="hero-social" />
    </div>
  </div>

  <div class="hero-visual" data-enter style="--enter-i: 3">
    <!-- 3D flip card: terminal ↔ profile photo. Auto-flips slowly;
         click / Enter flips manually; tilts toward the mouse. -->
    <div
      class="flip"
      id="hero-flip"
      role="button"
      tabindex="0"
      aria-label="Flip card showing a terminal window and Justin's profile photo. Press to flip."
    >
      <div class="flip-inner">
        <div class="face front">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="dot dot-r"></span>
              <span class="dot dot-y"></span>
              <span class="dot dot-g"></span>
              <span class="title">justin@homelab: ~</span>
            </div>
            <div class="terminal-body">
              <div><span class="prompt">~$</span> <span class="cmd">whoami --location</span></div>
              <div class="out">justin · houston, tx · uh cs '27</div>
              <div><span class="prompt">~$</span> <span class="cmd">cat stack.txt</span></div>
              <div class="out">typescript · react · node · python</div>
              <div class="out">docker · proxmox · linux · nginx</div>
              <div><span class="prompt">~$</span> <span class="cmd">systemctl status portfolio</span></div>
              <div class="out"><span class="ok">●</span> active (running) — self-hosted</div>
              <div><span class="prompt">~$</span> <span class="cmd">./deploy.sh --agents</span></div>
              <div class="out">✓ ai automations online</div>
              <div><span class="prompt">~$</span> <span class="cmd">ping papatenko.org</span></div>
              <div class="out">64 bytes: the art side is alive ✓</div>
            </div>
          </div>
        </div>
        <div class="face back">
          <img
            src="/images/profile.jpg"
            alt="Portrait of Justin Kondratenko"
            width="800"
            height="800"
            loading="eager"
            decoding="async"
          />
          <span class="back-caption mono">~$ whoami --photo</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 3rem;
    min-height: calc(88vh - 4rem);
    padding-block: 4rem;
  }
  .kicker { color: var(--text-muted); margin-bottom: 0.5rem; }
  .prompt { color: var(--gold); }
  .grad {
    /* flat accent — gradients read too "AI" */
    color: var(--accent);
  }
  .roles {
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    color: var(--accent);
    min-height: 1.6em;
    margin-bottom: 1rem;
  }
  .intro {
    color: var(--text-muted);
    max-width: 54ch;
    font-size: 1.05rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin: 1.6rem 0 1.8rem;
  }
  .ok { color: #34d399; } /* terminal status green — theme-independent */

  /* ── Flip card (terminal ↔ profile photo) ─────────────────── */
  .hero-visual { perspective: 1200px; }
  .flip {
    position: relative;
    /* square so the (square) profile photo shows in full */
    aspect-ratio: 1 / 1;
    width: min(100%, 420px);
    margin-left: auto;
    transform-style: preserve-3d;
    transition: transform 550ms var(--ease);
    will-change: transform;
    border-radius: var(--radius);
  }
  .flip.tilting { transition: transform 120ms ease-out; }
  .flip-inner {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    /* the slow, noticeable flip */
    transition: transform 1600ms cubic-bezier(0.45, 0.05, 0.2, 1);
  }
  .flip.flipped .flip-inner { transform: rotateY(180deg); }
  .face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
  }
  .front :global(.terminal) {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .front :global(.terminal-body) {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .back {
    transform: rotateY(180deg);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid rgba(244, 163, 64, 0.35);
    box-shadow: 0 24px 60px rgba(60, 20, 30, 0.35);
  }
  .back img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* photo is square — shows in full */
  }
  .back-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0.5rem 0.9rem;
    font-size: 0.75rem;
    color: #f4a340;
    background: linear-gradient(transparent, rgba(26, 20, 22, 0.85));
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: 0;
      padding-block: 3rem 2rem;
      gap: 2.2rem;
    }
    .flip { margin-inline: auto; }
  }
</style>

<script>
  // Typing animation for hero roles — fast, fluid, reduced-motion aware.
  import { site } from '../data/site';

  const el = document.getElementById('typed');
  const roles = site.roles;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (el && roles.length > 1 && !reduced) {
    let role = 0;
    let chars = roles[0]!.length;
    let deleting = true;

    const tick = () => {
      const current = roles[role]!;
      chars = deleting ? chars - 1 : chars + 1;
      el.textContent = current.slice(0, chars);

      let delay = deleting ? 32 : 58;
      if (!deleting && chars === current.length) {
        deleting = true;
        delay = 2100; // pause on full word
      } else if (deleting && chars === 0) {
        deleting = false;
        role = (role + 1) % roles.length;
        delay = 350;
      }
      setTimeout(tick, delay);
    };
    setTimeout(tick, 1800);
  }

  // ── Hero flip card: terminal ↔ profile photo ────────────────
  const flip = document.getElementById('hero-flip');
  if (flip) {
    const FLIP_EVERY = 7000; // slow but noticeable
    let hovering = false;

    const toggle = () => flip.classList.toggle('flipped');

    // Auto-flip on an interval (skipped for reduced motion, paused on hover)
    if (!reduced) {
      setInterval(() => {
        if (!hovering) toggle();
      }, FLIP_EVERY);
    }

    // Manual flip: click / Enter / Space
    flip.addEventListener('click', toggle);
    flip.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });

    // 3D tilt toward the mouse (same feel as the project cards)
    const fine = window.matchMedia('(pointer: fine)').matches;
    if (fine && !reduced) {
      flip.addEventListener('mouseenter', () => (hovering = true));
      flip.addEventListener('mousemove', (e) => {
        const r = flip.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        flip.classList.add('tilting');
        flip.style.transform = `rotateX(${(-py * 10).toFixed(2)}deg) rotateY(${(px * 12).toFixed(2)}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      flip.addEventListener('mouseleave', () => {
        hovering = false;
        flip.classList.remove('tilting');
        flip.style.transform = '';
      });
    }
  }
</script>
