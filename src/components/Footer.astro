---
import { site } from '../data/site';
import SocialLinks from './SocialLinks.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container inner">
    <p class="mono">
      <span class="prompt">~$</span> echo "© {year} {site.name}"
    </p>
    <SocialLinks />
    <p class="built mono">built with Astro + Claude Code · self-hosted on a Proxmox homelab</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 2.2rem;
    margin-top: 2rem;
  }
  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
  }
  .inner p { margin: 0; font-size: 0.85rem; color: var(--text-muted); }
  .prompt { color: var(--green); }
  .built { font-size: 0.75rem; }
</style>
