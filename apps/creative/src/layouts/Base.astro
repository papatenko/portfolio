---
import '../styles/global.css';
import { site } from '../data/content';

interface Props { title?: string; description?: string }
const {
  title = 'Papatenko — Video Editing, Thumbnails & Design by Justin Kondratenko',
  description = 'The creative side of Justin Kondratenko: video editing for YouTube creators and businesses, thumbnails that get clicked, logos, posters, and motion.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://papatenko.org').href} />
    <link rel="icon" type="image/png" href="/art/pixel-pfp-transparent.png" />
    <meta name="theme-color" content="#faf6ef" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://papatenko.org/art/pixel-pfp.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap"
    />
  </head>
  <body>
    <div class="backdrop" aria-hidden="true"></div>
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>

    <script>
      // Springy scroll reveal with stagger
      const observer = new IntersectionObserver(
        (entries) => {
          let i = 0;
          for (const e of entries) {
            if (e.isIntersecting) {
              (e.target as HTMLElement).style.setProperty('--reveal-delay', `${i++ * 80}ms`);
              e.target.classList.add('revealed');
              observer.unobserve(e.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
      );
      document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));
    </script>

    <script>
      // Banana cursor — same mascot as justinkondratenko.dev
      const fine = window.matchMedia('(pointer: fine)').matches;
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (fine && !reduced) {
        const SIZE = 36;
        const MORPH_MAX_W = 280;
        const MORPH_MAX_H = 110;
        const PAD = 6;
        const INTERACTIVE = 'a, button, .btn, input, textarea, [data-cursor]';

        const blob = document.createElement('div');
        blob.className = 'cursor-blob hidden';
        blob.innerHTML = `
          <svg class="banana" viewBox="0 0 40 40" width="36" height="36" aria-hidden="true">
            <defs>
              <linearGradient id="bnn" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#f6c95c"/>
                <stop offset="0.55" stop-color="#f4a340"/>
                <stop offset="1" stop-color="#e8871e"/>
              </linearGradient>
            </defs>
            <g transform="rotate(-14 20 20)">
              <path
                d="M9.2 5.6 C8.4 4.4 9.6 3.2 10.9 3.9 C12.2 11.5 16.4 19.4 23 24.1 C27.3 27.1 31.8 28.4 35.3 28 C36.9 27.8 37.7 29.5 36.4 30.8 C33.5 33.7 27.1 34.2 21.5 31.7 C13.4 28.1 8.3 20 7.1 11.2 C6.8 9 7.8 6.8 9.2 5.6 Z"
                fill="url(#bnn)" stroke="#2a1a1f" stroke-width="1.6" stroke-linejoin="round"/>
              <path d="M8.6 3.4 L11.6 3.2 L11 5.8 C10 5.9 9.2 5.6 8.9 4.9 Z" fill="#a4133c"/>
              <circle cx="36" cy="29.6" r="1.7" fill="#c2185b"/>
            </g>
          </svg>`;
        document.body.appendChild(blob);
        document.documentElement.classList.add('has-custom-cursor');

        let mx = innerWidth / 2, my = innerHeight / 2;
        let target: HTMLElement | null = null;
        const cur = { x: mx, y: my, w: SIZE, h: SIZE, r: SIZE / 2 };

        addEventListener('mousemove', (e) => {
          mx = e.clientX; my = e.clientY;
          blob.classList.remove('hidden');
        });
        document.addEventListener('mouseleave', () => blob.classList.add('hidden'));
        document.addEventListener('mouseover', (e) => {
          const el = (e.target as HTMLElement).closest<HTMLElement>(INTERACTIVE);
          if (el !== target && target) target.style.translate = '';
          target = el;
        });
        document.addEventListener('mouseout', (e) => {
          if (target && !target.contains(e.relatedTarget as Node)) {
            target.style.translate = '';
            target = null;
          }
        });
        const skipMorph = (el: HTMLElement) => el.tagName === 'INPUT' || el.tagName === 'TEXTAREA';
        const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

        const frame = () => {
          let tx = mx, ty = my, tw = SIZE, th = SIZE, tr = SIZE / 2;
          if (target && document.contains(target) && !skipMorph(target)) {
            const rect = target.getBoundingClientRect();
            if (rect.width <= MORPH_MAX_W && rect.height <= MORPH_MAX_H) {
              const cx = rect.left + rect.width / 2;
              const cy = rect.top + rect.height / 2;
              tw = rect.width + PAD * 2;
              th = rect.height + PAD * 2;
              tx = cx + (mx - cx) * 0.15;
              ty = cy + (my - cy) * 0.15;
              const elRadius = parseFloat(getComputedStyle(target).borderRadius) || 10;
              tr = Math.min(th / 2, elRadius + PAD);
              target.style.translate = `${((mx - cx) * 0.12).toFixed(1)}px ${((my - cy) * 0.12).toFixed(1)}px`;
              blob.classList.add('on-target', 'morphed');
            } else {
              tw = th = SIZE * 1.5;
              tr = th / 2;
              blob.classList.remove('on-target');
              blob.classList.add('morphed');
            }
          } else {
            blob.classList.remove('on-target', 'morphed');
          }
          const t = 0.22;
          cur.x = lerp(cur.x, tx, t); cur.y = lerp(cur.y, ty, t);
          cur.w = lerp(cur.w, tw, t); cur.h = lerp(cur.h, th, t);
          cur.r = lerp(cur.r, tr, t);
          blob.style.width = `${cur.w}px`;
          blob.style.height = `${cur.h}px`;
          blob.style.borderRadius = `${cur.r}px`;
          blob.style.transform = `translate(${cur.x - cur.w / 2}px, ${cur.y - cur.h / 2}px)`;
          requestAnimationFrame(frame);
        };
        requestAnimationFrame(frame);
      }
    </script>
  </body>
</html>
