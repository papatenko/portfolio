---
import { experience } from '../data/experience';
---

<section id="experience" class="section container" aria-labelledby="exp-title">
  <span class="section-label">experience</span>
  <h2 id="exp-title" data-reveal>Where I've been</h2>

  <ol class="timeline" role="list">
    {experience.map((job) => (
      <li class="entry" data-reveal>
        <div class="marker" aria-hidden="true"></div>
        <div class="content">
          <p class="dates mono">{job.start} — {job.end}</p>
          <h3>
            {job.role}
            <span class="at"> @ </span>
            {job.url ? (
              <a href={job.url} target="_blank" rel="noopener noreferrer">{job.company}</a>
            ) : (
              <span class="company">{job.company}</span>
            )}
          </h3>
          <p class="desc">{job.description}</p>
          <ul class="tags" role="list">
            {job.tech.map((t) => <li class="tag">{t}</li>)}
          </ul>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .timeline {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent-strong),
      color-mix(in srgb, var(--accent) 8%, transparent)
    );
  }
  .entry {
    position: relative;
    padding-left: 2.4rem;
    padding-bottom: 2.4rem;
  }
  .entry:last-child { padding-bottom: 0; }
  .marker {
    position: absolute;
    left: 0;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 3px solid var(--accent-strong);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
  }
  .dates { color: var(--text-muted); font-size: 0.8rem; margin: 0 0 0.3rem; }
  .content h3 { margin-bottom: 0.4rem; }
  .at { color: var(--text-muted); font-weight: 400; }
  .company { color: var(--accent); }
  .desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 68ch;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
