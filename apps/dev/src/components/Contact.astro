---
import { site } from '../data/site';

const hasForm = Boolean(site.contactFormEndpoint && site.contactFormAccessKey);
---

<section id="contact" class="section container" aria-labelledby="contact-title">
  <span class="section-label">contact</span>
  <h2 id="contact-title" data-reveal>Interested in working together?</h2>

  <div class="contact-grid">
    <div data-reveal>
      <p class="pitch">
        {site.availability}
      </p>
      <a class="email mono" href={`mailto:${site.email}`}>{site.email}</a>
      <p class="response">{site.responseTime}</p>
    </div>

    <form
      class="form"
      data-reveal
      method="POST"
      action={site.contactFormEndpoint || `mailto:${site.email}`}
      id="contact-form"
    >
      {hasForm && <input type="hidden" name="access_key" value={site.contactFormAccessKey} />}
      {hasForm && <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />}
      <div class="field">
        <label for="cf-name">Name</label>
        <input id="cf-name" name="name" type="text" required autocomplete="name" />
      </div>
      <div class="field">
        <label for="cf-email">Email</label>
        <input id="cf-email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="field">
        <label for="cf-message">Message</label>
        <textarea id="cf-message" name="message" rows="5" required></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Send message</button>
      <p class="form-status mono" role="status" aria-live="polite"></p>
      {!hasForm && (
        <p class="form-note">
          {/* Remove once contactFormEndpoint is set in src/data/site.ts */}
          Form opens your email client until a Web3Forms key is configured — see README.
        </p>
      )}
    </form>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    margin-top: 1rem;
    align-items: start;
  }
  .pitch { color: var(--text-muted); max-width: 40ch; }
  .email {
    display: inline-block;
    font-size: clamp(1.05rem, 3vw, 1.3rem);
    font-weight: 700;
    color: var(--accent);
    border-bottom: 2px solid var(--border-strong);
    padding-bottom: 2px;
    margin: 0.8rem 0;
  }
  .email:hover { color: var(--text); border-color: var(--accent); }
  .response { color: var(--text-muted); font-size: 0.9rem; }

  .form {
    display: grid;
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
  }
  .field { display: grid; gap: 0.35rem; }
  label { font-size: 0.85rem; font-weight: 600; color: var(--text-muted); }
  input, textarea {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font: inherit;
    padding: 0.65rem 0.85rem;
    transition: border-color var(--speed) var(--ease);
    resize: vertical;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent);
  }
  .hp { display: none; }
  .form-status:empty, .form-status { margin: 0; font-size: 0.85rem; color: var(--gold); }
  .form-note { margin: 0; font-size: 0.8rem; color: var(--text-muted); }

  @media (max-width: 860px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>

<script>
  // Progressive enhancement: AJAX submit when a form endpoint is configured.
  import { site } from '../data/site';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = form?.querySelector('.form-status') as HTMLElement | null;

  if (form && site.contactFormEndpoint) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (status) status.textContent = 'Sending…';
      try {
        const res = await fetch(site.contactFormEndpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(String(res.status));
        form.reset();
        if (status) status.textContent = '✓ Message sent — talk soon!';
      } catch {
        if (status) status.textContent = '✗ Something broke — email me directly instead.';
      }
    });
  }
</script>
